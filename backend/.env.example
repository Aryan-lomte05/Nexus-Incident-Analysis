# ─── AI Runtime ───────────────────────────────
# "dev"  → Ollama (localhost:11434, llama3.1:8b)
# "prod" → Groq   (api.groq.com, llama-3.1-8b-instant)
ENV=dev
GROQ_API_KEY=gsk_your_groq_key_here

# ─── Datadog ──────────────────────────────────
# Get from: app.datadoghq.com → Organization Settings → API Keys
DATADOG_API_KEY=
# Get from: app.datadoghq.com → Organization Settings → Application Keys
DATADOG_APP_KEY=
# Your DD site: datadoghq.com | datadoghq.eu | us3.datadoghq.com | us5.datadoghq.com
DATADOG_SITE=datadoghq.com

# ─── PagerDuty ────────────────────────────────
# Get from: app.pagerduty.com → User Icon → User Settings → API Access → Create New API Key
PAGERDUTY_API_KEY=
